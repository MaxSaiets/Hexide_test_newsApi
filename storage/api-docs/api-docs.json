{
    "openapi": "3.0.0",
    "info": {
        "title": "News API",
        "description": "API для управління новинами з блоковою структурою контенту.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api/v1",
            "description": "API v1"
        }
    ],
    "paths": {
        "/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Реєстрація нового користувача",
                "operationId": "5d4fa5d5607ed675ba93907e1fc94534",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Макс"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "max@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    },
                                    "avatar": {
                                        "description": "Аватар (файл)",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "bio": {
                                        "type": "string",
                                        "example": "Про мене"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Успішна реєстрація"
                    },
                    "422": {
                        "description": "Помилка валідації"
                    }
                }
            }
        },
        "/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Авторизація користувача",
                "operationId": "67d6d0fdd54fba132e1b6f55ca254183",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "max@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Успішний вхід"
                    },
                    "401": {
                        "description": "Невірні облікові дані"
                    }
                }
            }
        },
        "/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Вихід з акаунта",
                "operationId": "28d48c13fca984400ac8de99f54ee13a",
                "responses": {
                    "200": {
                        "description": "Успішний вихід"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/news": {
            "get": {
                "tags": [
                    "Public News"
                ],
                "summary": "Отримати список опублікованих новин",
                "operationId": "a99e473d9c49fcba2c46751d22262e4d",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Пошук по назві або опису",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Кількість на сторінку (макс 50)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Номер сторінки",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список новин"
                    }
                }
            }
        },
        "/news/{slug}": {
            "get": {
                "tags": [
                    "Public News"
                ],
                "summary": "Отримати новину за slug (з блоками контенту)",
                "operationId": "953f9af5584077615cc3239a17aca97e",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "description": "Slug новини",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Дані новини з блоками"
                    },
                    "404": {
                        "description": "Новину не знайдено"
                    }
                }
            }
        },
        "/user_news/{user_news}/blocks": {
            "post": {
                "tags": [
                    "News Blocks"
                ],
                "summary": "Створити блок контенту для новини",
                "operationId": "744673d98150866a4a530b46b6e58a00",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "news_id",
                                    "content[type]"
                                ],
                                "properties": {
                                    "news_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "content[type]": {
                                        "type": "string",
                                        "enum": [
                                            "text",
                                            "image",
                                            "text_image_right",
                                            "text_image_left"
                                        ],
                                        "example": "text"
                                    },
                                    "content[text]": {
                                        "type": "string",
                                        "example": "Текст блоку"
                                    },
                                    "content[image]": {
                                        "description": "Картинка блоку",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "position": {
                                        "type": "integer",
                                        "example": 0
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Блок створено"
                    },
                    "401": {
                        "description": "Неавторизований"
                    },
                    "403": {
                        "description": "Заборонено"
                    },
                    "422": {
                        "description": "Помилка валідації"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/blocks/{id}": {
            "post": {
                "tags": [
                    "News Blocks"
                ],
                "summary": "Оновити блок контенту (POST з _method=PUT для файлів)",
                "operationId": "056357b22964859762c13e699156beb7",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID блоку",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "properties": {
                                    "_method": {
                                        "description": "Спуфінг методу",
                                        "type": "string",
                                        "example": "PUT"
                                    },
                                    "content[type]": {
                                        "type": "string",
                                        "enum": [
                                            "text",
                                            "image",
                                            "text_image_right",
                                            "text_image_left"
                                        ]
                                    },
                                    "content[text]": {
                                        "type": "string"
                                    },
                                    "content[image]": {
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "position": {
                                        "type": "integer"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Блок оновлено"
                    },
                    "401": {
                        "description": "Неавторизований"
                    },
                    "403": {
                        "description": "Заборонено"
                    },
                    "422": {
                        "description": "Помилка валідації"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "News Blocks"
                ],
                "summary": "Видалити блок контенту",
                "operationId": "85ecdfdb4bb1a7430f41c9c72cfc7c4b",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID блоку",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Блок видалено"
                    },
                    "401": {
                        "description": "Неавторизований"
                    },
                    "403": {
                        "description": "Заборонено"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/user_news": {
            "get": {
                "tags": [
                    "User News"
                ],
                "summary": "Отримати список власних новин",
                "operationId": "761821e8862eabbcccff1edbebf2552f",
                "parameters": [
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Пошук",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "is_published",
                        "in": "query",
                        "description": "Фільтр за статусом",
                        "required": false,
                        "schema": {
                            "type": "boolean"
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Кількість на сторінку",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Номер сторінки",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список новин користувача"
                    },
                    "401": {
                        "description": "Неавторизований"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "User News"
                ],
                "summary": "Створити новину",
                "operationId": "8fd8b02bdf1f2561026fc6c70f094902",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "title"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "Назва новини"
                                    },
                                    "short_description": {
                                        "type": "string",
                                        "example": "Короткий опис"
                                    },
                                    "image": {
                                        "description": "Картинка новини",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "is_published": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "published_at": {
                                        "type": "string",
                                        "format": "date-time"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Новину створено"
                    },
                    "401": {
                        "description": "Неавторизований"
                    },
                    "422": {
                        "description": "Помилка валідації"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
