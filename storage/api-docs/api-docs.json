                "tags": [
                    "User News"
                ],
                "summary": "Створити новину",
                "operationId": "b1f57450a61284aa43ee78e67bc9ace7",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "title"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "Назва новини"
                                    },
                                    "short_description": {
                                        "type": "string",
                                        "example": "Короткий опис"
                                    },
                                    "image": {
                                        "description": "Картинка новини",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "is_published": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "published_at": {
                                        "type": "string",
                                        "format": "date-time"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Новину створено"
                    },
                    "401": {
                        "description": "Неавторизований"
                    },
                    "422": {
                        "description": "Помилка валідації"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
